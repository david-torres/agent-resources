{{> breadcrumbs}}
<h1 class="title is-2">
  {{character.name}}
  {{#if character.is_deceased}}
  <span class="tag is-dark is-medium ml-2">
    <span class="icon"><i class="fas fa-skull"></i></span>
    <span>Deceased</span>
  </span>
  {{/if}}
  {{> private-badge isPublic=character.is_public}}
</h1>
{{#if characterClass}}
<p class="subtitle is-6 has-text-grey">
  <span class="tag is-light">{{capitalize characterClass.rules_edition}} {{characterClass.rules_version}}</span>
</p>
{{/if}}
<div class="columns">
  <div class="column is-one-third">
    {{#if character.image_url}}
    <div
      class="image-crop-render"
      data-cropped-image
      data-image-src="{{character.image_url}}"
      data-crop-x="{{character.image_crop.x}}"
      data-crop-y="{{character.image_crop.y}}"
      data-crop-width="{{character.image_crop.width}}"
      data-crop-height="{{character.image_crop.height}}"
      role="img"
      aria-label="{{character.name}}"
    ></div>
    {{else if characterClass.image_url}}
    <div
      class="image-crop-render"
      data-cropped-image
      data-image-src="{{characterClass.image_url}}"
      data-crop-x="{{characterClass.image_crop.x}}"
      data-crop-y="{{characterClass.image_crop.y}}"
      data-crop-width="{{characterClass.image_crop.width}}"
      data-crop-height="{{characterClass.image_crop.height}}"
      role="img"
      aria-label="{{character.name}} ({{characterClass.name}})"
    ></div>
    {{else}}
    <div class="notification is-info">No image available</div>
    {{/if}}

    <div class="box mt-4">
      <h3 class="title is-4">Character Info</h3>
      <p><strong>Class:</strong>
        {{#if characterClass}}
        <a href="/classes/{{characterClass.id}}/{{characterClass.name}}">{{character.class}}</a>
        {{else}}
        {{character.class}}
        {{/if}}
      </p>
      <p><strong>Level:</strong> {{character.level}}</p>
      {{#if ownerProfile}}
      {{#if (lookup ownerProfile 'is_public')}}
      <p><strong>Owner:</strong> <a href="/profile/view/{{encodeURIComponentH ownerProfile.name}}">{{ownerProfile.name}}</a></p>
      {{else}}
      <p><strong>Owner:</strong> {{ownerProfile.name}}</p>
      {{/if}}
      {{/if}}
      {{#if (lt character.level 10)}}
      <p class="is-size-7">
        {{#if (eq effectiveVersion 'v2')}}
        V2: Need {{subtract (getTotalV2MissionsNeeded (add character.level 1)) character.completed_missions}} more
        missions to reach level {{add character.level 1}}
        {{else}}
        V1: Need {{subtract (getTotalV1MissionsNeeded (add character.level 1)) character.completed_missions}} more
        missions to reach level {{add character.level 1}}
        {{/if}}
      </p>
      {{/if}}
      <p><strong>Completed Missions:</strong> {{character.completed_missions}}</p>
      <p><strong>Commissary Reward:</strong> {{character.commissary_reward}}</p>
    </div>

    <div class="box">
      <h3 class="title is-4">Personality</h3>
      <div class="tags is-centered">
        {{#each character.traits}}
        <span class="tag is-primary is-medium">{{capitalize this}}</span>
        {{/each}}
      </div>
    </div>

    <div class="box">
      <h3 class="title is-4">Recent Missions</h3>
      {{#if recentMerged.length}}
      <div class="content">
        <ul>
          {{#each recentMerged}}
          {{#if (eq this._kind "offscreen")}}
            <li>
              {{> offscreen-mission-entry entry=this character=../character profile=../profile canViewSource=true}}
            </li>
          {{else}}
            {{#or this.is_public (eq ../profile.id this.creator_id)}}
            <li>
              <strong><a href="/missions/{{this.id}}">{{this.name}}</a></strong>
              <br>
              {{#if ../profile}}
              <small>{{date_tz this.date "MMM D, YYYY" ../profile.timezone}} - {{this.outcome}}</small>
              {{else}}
              <small>{{date this.date "MMM D, YYYY"}} - {{this.outcome}}</small>
              {{/if}}
            </li>
            {{/or}}
          {{/if}}
          {{/each}}
        </ul>
        <p class="has-text-right">
          <a href="/missions/character/{{character.id}}">View all missions →</a>
        </p>
      </div>
      {{else}}
      <p class="has-text-centered has-text-grey">No missions yet. Add one below or from the <a href="/missions">Missions</a> page.</p>
      {{/if}}

      {{#if profile}}
      {{#if (eq character.creator_id profile.id)}}
      <form hx-post="/missions" hx-trigger="submit" class="mt-4">
        <input type="hidden" name="characters[]" value="{{character.id}}">
        <div class="field has-addons">
          <div class="control is-expanded">
            <input class="input" type="text" name="name" placeholder="Mission name" required>
          </div>
          <div class="control">
            <button class="button is-primary" type="submit">Add Mission</button>
          </div>
        </div>
      </form>
      {{#if (eq effectiveVersion 'v2')}}
      <div class="mt-3">
        <a href="/characters/{{character.id}}/offscreen-missions/new"
           class="button is-link is-light is-fullwidth">
          <span class="icon"><i class="fas fa-bolt"></i></span>
          <span>Spend Conduit Credit (Offscreen Mission)</span>
        </a>
        <p class="help">Hosted a mission? Spend a Conduit Credit to add an offscreen mission to this character's log.</p>
      </div>
      {{/if}}
      {{/if}}
      {{/if}}
    </div>

    {{#if profile}}
    {{#if (eq character.creator_id profile.id)}}
    <div class="field is-grouped is-pulled-right">
      <div class="control">
        <div class="buttons has-addons mb-0">
          <a href="/characters/{{character.id}}/edit" class="button is-warning">Edit Character</a>
          <button type="button" class="button is-link is-light" id="levelUpBtn" data-completed-missions="{{character.completed_missions}}">
            <span class="icon"><i class="fas fa-arrow-up"></i></span>
            <span>Level Up</span>
          </button>
        </div>
      </div>
      <div class="control">
        <div class="dropdown is-right" id="export-dropdown">
          <div class="dropdown-trigger">
            <button class="button is-white" aria-haspopup="true" aria-controls="export-menu" onclick="document.getElementById('export-dropdown').classList.toggle('is-active')" title="Export">
              <span class="icon"><i class="fas fa-ellipsis-vertical"></i></span>
            </button>
          </div>
          <div class="dropdown-menu" id="export-menu" role="menu">
            <div class="dropdown-content">
              <a href="/characters/{{character.id}}/export?format=markdown" class="dropdown-item">
                <span class="icon"><i class="fas fa-file-alt"></i></span>
                <span>Markdown (.md)</span>
              </a>
              <a href="/characters/{{character.id}}/export?format=json" class="dropdown-item">
                <span class="icon"><i class="fas fa-file-code"></i></span>
                <span>JSON (.json)</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    {{/if}}
    {{/if}}
  </div>

  <div class="column is-two-thirds">
    <div class="box" id="statsBox" data-character-id="{{character.id}}" data-character-name="{{character.name}}" data-character-level="{{character.level}}">
      <div class="level is-mobile mb-3">
        <div class="level-left">
          <h3 class="title is-4 mb-0">Stats</h3>
        </div>
        {{#if profile}}
        {{#if (eq character.creator_id profile.id)}}
        <div class="level-right">
          <button type="button" class="button is-small is-link is-light" id="statsUnlockBtn">
            <span class="icon"><i class="fas fa-pen"></i></span>
            <span>Edit</span>
          </button>
        </div>
        {{/if}}
        {{/if}}
      </div>
      <div id="statsReadOnly" class="wizard-stat-grid">
        {{#each statList}}
        <div class="wizard-stat-row" data-stat="{{this}}" data-value="{{lookup ../character this}}">
          <div class="wizard-stat-name">{{capitalize this}}</div>
          <div class="wizard-stat-boxes">
            {{#range 0 (lookup ../character this)}}
            <div class="wizard-stat-box is-class" title="{{capitalize ../this}}: point">
              <i class="fa-regular fa-square-plus" aria-hidden="true"></i>
            </div>
            {{/range}}
            {{#range (lookup ../character this) 5}}
            <div class="wizard-stat-box is-locked" title="{{capitalize ../this}}: locked">
              <i class="fa-regular fa-square-plus" aria-hidden="true"></i>
            </div>
            {{/range}}
          </div>
        </div>
        {{/each}}
      </div>
      <div id="statsEditor" hidden>
        {{> character-stats-editor}}
      </div>
    </div>

    <div class="box">
      <h3 class="title is-4">Class Abilities</h3>
      <div class="columns is-multiline">
        {{#each character.abilities}}
        <div class="column is-one-third">
          {{#if (lookup this 'description')}}
          <span class="is-size-5" data-tooltip-markdown="#ability-{{dashcase (lookup this 'class_id')}}-{{dashcase (lookup this 'name')}}">{{capitalize (lookup this 'name')}}</span>
          <div id="ability-{{dashcase (lookup this 'class_id')}}-{{dashcase (lookup this 'name')}}" class="is-hidden">
            {{{markdown (lookup this 'description')}}}
          </div>
          {{else}}
          <div class="is-size-5">{{capitalize (lookup this 'name')}}</div>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>

    {{#if (eq effectiveVersion 'v1')}}
    {{#if character.perks}}
    <div class="box">
      <h3 class="title is-4">Ability Perks</h3>
      <div class="content">
        {{{markdown character.perks}}}
      </div>
    </div>
    {{/if}}
    {{/if}}

    <div class="box">
      <h3 class="title is-4">Signature Gear</h3>
      <div class="columns is-multiline">
        {{#each character.gear}}
        <div class="column is-one-third">
          {{#if (lookup this 'description')}}
          <span class="is-size-5" data-tooltip-markdown="#gear-{{dashcase (lookup this 'class_id')}}-{{dashcase (lookup this 'name')}}">{{capitalize (lookup this 'name')}}</span>
          <div id="gear-{{dashcase (lookup this 'class_id')}}-{{dashcase (lookup this 'name')}}" class="is-hidden">
            {{{markdown (lookup this 'description')}}}
          </div>
          {{else}}
          <div class="is-size-5">{{capitalize (lookup this 'name')}}</div>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>

    {{#if character.common_items}}
    {{#if character.common_items.length}}
    <div class="box">
      <h3 class="title is-4">Common Items</h3>
      <div class="content">
        <ul>
          {{#each character.common_items}}
          <li>{{{markdown this}}}</li>
          {{/each}}
        </ul>
      </div>
    </div>
    {{/if}}
    {{/if}}

    {{#if (eq effectiveVersion 'v2')}}
      {{#if character.quirks.length}}
      <div class="box">
        <h3 class="title is-4">Quirks</h3>
        <ul>
          {{#each character.quirks}}
          <li><strong>{{this.name}}</strong>{{#if this.description}} — {{this.description}}{{/if}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if character.accessories.length}}
      <div class="box">
        <h3 class="title is-4">Accessories</h3>
        <ul>
          {{#each character.accessories}}
          <li><strong>{{this.name}}</strong>{{#if this.description}} — {{this.description}}{{/if}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if character.ability_perks.length}}
      <div class="box">
        <h3 class="title is-4">Ability Perks</h3>
        {{#each character.abilities}}
          {{#with (perksForAbility ../character.ability_perks this.id) as |perks|}}
            {{#if perks.length}}
            <h4 class="title is-5">{{capitalize ../this.name}}</h4>
            <ol>
              {{#each perks}}
                <li>
                  {{this.text}}
                  {{#if this.compounds_with}}<span class="tag is-info is-light ml-2">compounding</span>{{/if}}
                </li>
              {{/each}}
            </ol>
            {{/if}}
          {{/with}}
        {{/each}}
      </div>
      {{/if}}

    {{/if}}

    {{#if (and (eq effectiveVersion 'v1') character.additional_gear)}}
    <div class="box">
      <h3 class="title is-4">
        Additional Gear
        <span class="tag is-warning is-light ml-2">Deprecated</span>
      </h3>
      <p class="help mb-2">This field is deprecated. Use Common Items instead.</p>
      <div class="content">
        {{{markdown character.additional_gear}}}
      </div>
    </div>
    {{/if}}

    {{#if character.appearance}}
    <div class="box">
      <h3 class="title is-4">Appearance</h3>
      <div class="content">
        {{{markdown character.appearance}}}
      </div>
    </div>
    {{/if}}

    {{#if character.background}}
    <div class="box">
      <h3 class="title is-4">Background</h3>
      <div class="content">
        {{{markdown character.background}}}
      </div>
    </div>
    {{/if}}

    {{#if character.flavor}}
    <div class="box">
      <h3 class="title is-4">Flavor</h3>
      <div class="content">
        {{{markdown character.flavor}}}
      </div>
    </div>
    {{/if}}

    {{#if character.ideas}}
    <div class="box">
      <h3 class="title is-4">Ideas</h3>
      <div class="content">
        {{{markdown character.ideas}}}
      </div>
    </div>
    {{/if}}

    {{#if profile}}
    {{#if (eq character.creator_id profile.id)}}
    {{#if character.private_notes}}
    <div class="box">
      <h3 class="title is-4">
        <span class="icon-text">
          <span class="icon"><i class="fas fa-lock"></i></span>
          <span>Private Notes</span>
        </span>
      </h3>
      <div class="content">
        {{{markdown character.private_notes}}}
      </div>
    </div>
    {{/if}}
    {{/if}}
    {{/if}}

  </div>
</div>

{{> character-level-up}}

<script src="/js/character-common.js" defer></script>
<script src="/js/character-stats.js" defer></script>
<script src="/js/character-level-up.js" defer></script>
