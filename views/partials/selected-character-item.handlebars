<li>
  {{character.name}}
  <button type="button"
    class="button is-small is-danger is-light"
    hx-delete="/missions/{{mission.id}}/characters/{{character.id}}"
    hx-target="closest li"
    hx-swap="outerHTML">Remove</button>
  <input type="hidden" name="characters[]" value="{{character.id}}">
</li>
